# gin-tutorial 環境変数設定ファイル
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# .env はGitにコミットしないでください（.gitignoreに設定済み）。
# 本番環境では .env ではなく直接環境変数を設定してください。

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=gin_tutorial
# true にすると起動時にシードデータを投入する
DB_SEED=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Gin ---
# debug / release / test
GIN_MODE=debug

# gRPC サーバーアドレス（v6 ハンドラーが接続する先）
# デフォルト: localhost:50051
# GRPC_ADDR=localhost:50051
